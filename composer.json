{
    "name": "justkidding96/aardvark-seo",
    "description": "Save time and get your Statamic site to rank better with Aardvark SEO addon for Statamic CMS.",
    "version": "5.0.5",
    "type": "statamic-addon",
    "keywords": [
        "Statamic",
        "Aardvark",
        "SEO",
        "Google",
        "sitemaps",
        "redirects",
        "schema",
        "tools",
        "meta data",
        "opengraph",
        "Candour",
        "WithCandour"
    ],
    "authors": [
        {
            "name": "justkidding96",
            "email": "info@thenextgen.io"
        }
    ],
    "autoload": {
        "psr-4": {
            "WithCandour\\AardvarkSeo\\": "src"
        }
    },
    "extra": {
        "statamic": {
            "name": "Aardvark SEO",
            "description": "Aardvark SEO addon for Statamic CMS."
        },
        "laravel": {
            "providers": [
                "WithCandour\\AardvarkSeo\\ServiceProvider"
            ]
        }
    },
    "require": {
        "spatie/schema-org": "^3.2",
        "statamic/cms": "^5.0",
        "whitecube/lingua": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    }
}
